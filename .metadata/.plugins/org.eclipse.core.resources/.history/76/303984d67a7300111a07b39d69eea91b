import java.util.Queue;

public class QueueDemo {
	public stativ void main(String[] args) {
		Queue<String> que = new Linkedlist<String>();
		
		que.offer("Apple");
		que.offer("Banana");
		que.offer("Cherry");
		
		System.out.println(que.peek());
		
		while(!que.isEmpty()) {
			System.out.println(que.poll());
		}
	}

}
